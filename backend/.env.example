# ── APP ───────────────────────────────────────────────────────────────────────
APP_NAME="MarineXchange Africa API"
APP_VERSION="1.0.0"
ENVIRONMENT=development          # development | staging | production
DEBUG=true

# ── SUPABASE ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here     # NEVER expose to frontend
SUPABASE_JWT_SECRET=your-jwt-secret-here                  # Project Settings > API > JWT Secret

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard > Project Settings > Database > Connection string (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── EMAIL (RESEND) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@marinexchange.africa
EMAIL_FROM_NAME="MarineXchange Africa"

# ── FINANCE RULES (fixed — do not change without architectural review) ─────────
DUAL_CONTROL_THRESHOLD_USD=100000
MIN_FACILITATION_RATE=0.02
MAX_FACILITATION_RATE=0.15
DOWNPAYMENT_PERCENT=80
FINANCING_REQUEST_TIMEOUT_DAYS=7
INSTALLMENT_GRACE_PERIOD_DAYS=5

# ── STORAGE ───────────────────────────────────────────────────────────────────
MAX_PRODUCT_IMAGES=20
MIN_PRODUCT_IMAGES=10
MAX_IMAGE_SIZE_MB=2
SIGNED_URL_EXPIRY_SECONDS=900   # 15 minutes

# ── SECURITY ──────────────────────────────────────────────────────────────────
# Cloudflare — validates all requests came through Cloudflare WAF
CLOUDFLARE_TUNNEL_SECRET=

# Rate limiting (requests per minute)
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_AUTH=10
RATE_LIMIT_UPLOAD=20
